# Public site URL — used for canonical links, sitemap and OG tags.
# On Railway set this to the generated/custom domain.
NUXT_PUBLIC_SITE_URL=https://creativefilmmaking.is

# SMTP for the "Request an offer" form (server-only).
# Leave unset in dev — submissions are logged to the console instead.
NUXT_SMTP_HOST=
NUXT_SMTP_PORT=587
NUXT_SMTP_USER=
NUXT_SMTP_PASS=
# Where offer requests are delivered
NUXT_CONTACT_TO=

# Business contact details shown in the footer and on the contact page
NUXT_PUBLIC_CONTACT_ADDRESS=Reykjavík, Iceland
NUXT_PUBLIC_CONTACT_PHONE=+354 000 0000
NUXT_PUBLIC_CONTACT_EMAIL=info@creativefilmmaking.is
