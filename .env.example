# Public site URL — used for canonical links, sitemap and OG tags.
# On Railway set this to the generated/custom domain.
NUXT_PUBLIC_SITE_URL=https://creativefilmmaking.is

# SMTP for the "Request an offer" form, quote-request notifications and
# customer offer emails (server-only).
# Leave unset in dev — submissions are logged to the console instead.
# For Resend: host smtp.resend.com, port 465, user "resend", pass = API key.
NUXT_SMTP_HOST=
NUXT_SMTP_PORT=587
NUXT_SMTP_USER=
NUXT_SMTP_PASS=
# From address when the SMTP user isn't a mailbox (Resend: a verified-domain
# address, or onboarding@resend.dev before the domain is verified).
NUXT_MAIL_FROM=
# Where offer requests are delivered
NUXT_CONTACT_TO=

# Admin panel at /admin — pick a long, unique password. Unset = panel disabled.
NUXT_ADMIN_PASSWORD=

# Where the SQLite database (app.sqlite — vehicles, equipment, quote requests,
# offers) and uploaded photos live. Defaults to ./.data — on Railway, mount a
# volume and point this at it (/data) so admin edits survive redeploys.
NUXT_DATA_DIR=

# Railway only: pin the Node major so the better-sqlite3 prebuilt binary
# matches the runtime ABI across rebuilds.
# NIXPACKS_NODE_VERSION=22

# Business contact details shown in the footer and on the contact page
NUXT_PUBLIC_CONTACT_ADDRESS=Reykjavík, Iceland
NUXT_PUBLIC_CONTACT_PHONE=+354 772 4968
NUXT_PUBLIC_CONTACT_EMAIL=info@creativefilmmaking.is
